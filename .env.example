PORT=3000

# Default is true so the MVP runs without paid API keys.
MOCK_MODE=true

# Public HTTPS URL for LINE webhooks and image assets, e.g. https://example.com
PUBLIC_BASE_URL=

# Optional HTTPS JPG/PNG/WEBP URL used as the LINE image message and Flex hero.
# LINE image messages require publicly accessible HTTPS image URLs.
DAILY_HEALTH_IMAGE_URL=

# LINE Official Account / Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Target chat can be a userId, groupId, or roomId from webhook events.
LINE_TARGET_CHAT_ID=

# Comma-separated LINE user IDs that receive moderation alerts.
LINE_ADMIN_USER_IDS=

# Protects POST /admin/daily-push when set.
ADMIN_WEBHOOK_SECRET=

# Asia/Taipei 24-hour time. Server must be running at this time.
DAILY_PUSH_TIME=08:00
DAILY_AI_QUOTA=10
AI_TRIGGER_PATTERN=^(AI|ai|問AI|請問AI)[:：\s]+

# Google AI Studio / Gemini settings.
# Gemini 2.5 Flash Image is the official Nano Banana image model.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-flash-latest
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Seedance video API settings.
# Replace these with the provider endpoint and response mapping you use.
SEEDANCE_API_URL=
SEEDANCE_API_KEY=

# Supabase for the BaZi creator app MVP.
# Keep SERVICE_ROLE_KEY server-side only. Never expose it in browser JavaScript.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=creator-videos
